# MiMoTTS example configuration
# Copy this file to .env before running docker compose.

# Default admin token for first login. Change it immediately in production.
ADMIN_TOKEN=mimotts

# Service listen address inside the container.
ADDR=:7117

# Persistent data directory inside the container.
DATA_DIR=/app/data

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# If true, /api/tts and /v1/audio/speech require an External API Key.
REQUIRE_EXTERNAL_KEY=false

# Optional CORS origin, for example: https://example.com
CORS_ORIGIN=
